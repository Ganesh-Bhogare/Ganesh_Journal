# Copy to: server/src/scripts/funded_bridge.env
# Then fill values and run mt5_readonly_bridge.py

# API endpoint of Ganesh Journal backend
BRIDGE_API_URL=http://localhost:4002/api/funded/sync-readonly

# Must match server FUNDED_BRIDGE_TOKEN in server/.env
FUNDED_BRIDGE_TOKEN=17BAC4263jrwS6JfFvg058lHGbmikD3ZusNqROahMyXLxnEtp

# Provider label shown in notes
FUNDED_PROVIDER=Goat Funded Trader

# Optional custom account id. Default: MT5_LOGIN
FUNDED_ACCOUNT_ID=314650897

# Poll interval seconds
BRIDGE_POLL_SECONDS=20

# How many days of history to inspect each cycle
BRIDGE_LOOKBACK_DAYS=3650

# State file for last synced ticket
BRIDGE_STATE_FILE=server/src/scripts/.funded_bridge_state.json

# MT5 terminal credentials (required)
MT5_LOGIN=314650897
MT5_PASSWORD=your_mt5_password
MT5_SERVER=GoatFunded-Server

# Optional terminal exe path if auto-detect fails
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
