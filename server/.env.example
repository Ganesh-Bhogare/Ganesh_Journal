# Server
PORT=4000
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/ganesh_journal?retryWrites=true&w=majority&appName=TradeJournal
JWT_SECRET=super-secret-change-me
UPLOAD_DIR=uploads
CORS_ORIGIN=http://localhost:5173

# Optional: External APIs
FOREX_API_KEY=
ECONOMIC_CALENDAR_API_URL=

# Economic Calendar (TradingEconomics)
# Free option: leave TRADING_ECONOMICS_API_KEY empty to use the public guest key from their docs (rate-limited).
TRADING_ECONOMICS_API_KEY=
TRADING_ECONOMICS_BASE_URL=https://api.tradingeconomics.com
CALENDAR_CACHE_TTL_SECONDS=180

# Calendar timezone used to decide what "today" means (recommended for India)
CALENDAR_TIMEZONE=Asia/Kolkata

# ForexFactory-style strict filtering (best-effort, not an official FF match)
# When enabled, reduces "extra" events by limiting currencies and excluding keywords.
CALENDAR_FF_STRICT=
# Comma-separated currency codes to include when strict mode is on.
CALENDAR_ALLOWED_CURRENCIES=USD,EUR,GBP,JPY,AUD,NZD,CAD,CHF,CNY
# Comma-separated keywords to exclude from event/category text when strict mode is on.
CALENDAR_EXCLUDE_KEYWORDS=speech,auction

# AI API (OpenAI-compatible)
# Create a key from OpenAI/DeepSeek/OpenRouter and set it here. Keep it server-side (do NOT put in frontend).
OPENAI_API_KEY=
# Model examples:
# - OpenAI: gpt-4o-mini, gpt-4o
# - DeepSeek: deepseek-chat, deepseek-reasoner
# - OpenRouter: meta-llama/llama-3.1-8b-instruct, etc.
OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI-compatible base URL
# - For OpenAI: leave empty (default https://api.openai.com/v1)
# - For DeepSeek: https://api.deepseek.com
# - For OpenRouter keys (sk-or-...): https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.deepseek.com


# Optional: shown in OpenRouter dashboard
OPENAI_APP_NAME=TradeJournal
# Optional: shown in OpenRouter dashboard (your site URL)
OPENAI_HTTP_REFERER=

# News (RSS/Atom)
# Comma-separated list of RSS/Atom feed URLs.
# Example:
# NEWS_FEEDS=https://www.forexlive.com/feed/,https://www.investing.com/rss/news_95.rss
NEWS_FEEDS=
NEWS_CACHE_TTL_SECONDS=180
NEWS_DEFAULT_LIMIT=200
NEWS_MAX_LIMIT=500

# Indian Momentum Screener (TradeStorm-style)
# Optional symbol universe, comma-separated Yahoo symbols (e.g. RELIANCE.NS,TCS.NS)
INDIAN_SCREENER_SYMBOLS=
INDIAN_SCREENER_CACHE_TTL_SECONDS=120
# Core engine thresholds
INDIAN_SCREENER_MOMENTUM_THRESHOLD=2
INDIAN_SCREENER_VOLUME_RATIO_THRESHOLD=1.5
INDIAN_SCREENER_LOOKBACK_MINUTES=15
# Number of prior 5m bars used for baseline volume average and breakout context
INDIAN_SCREENER_BASELINE_BARS=24

# Advanced strict mode (optional)
INDIAN_SCREENER_STRICT_DEFAULT=
INDIAN_SCREENER_RVOL_THRESHOLD=2
INDIAN_SCREENER_RSI_BULLISH_THRESHOLD=60
INDIAN_SCREENER_RSI_BEARISH_THRESHOLD=40
INDIAN_SCREENER_GAP_THRESHOLD_PERCENT=2
